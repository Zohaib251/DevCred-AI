# GitVibe Backend Environment Variables
# Rename this file to .env and fill in the values.

# GitHub API Token (optional)
# Used for fetching repository data. If not provided, GitHub validation will be limited.
# Generate a token here: https://github.com/settings/tokens
GITHUB_TOKEN=""

# Google Gemini API Key (required)
# Used for AI-powered resume analysis.
# Get your API key from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# JWT Secret Key (required)
# A strong, random string used for signing authentication tokens.
# You can generate one with: openssl rand -hex 32
JWT_SECRET_KEY=""

# Backend server port (optional, defaults to 8000)
BACKEND_PORT=8000

# Redis URL for caching (optional, defaults to in-memory mock)
# Example: "redis://localhost:6379"
REDIS_URL="mock"

# Database URL (optional, defaults to a local SQLite file)
# Example: "postgresql://user:password@host:port/dbname"
DATABASE_URL="sqlite:///./gitvibe.db"
