# === GitVibe Repository Ignore Rules ===

# 1. ISOLATE ENVIRONMENT VARIABLES & SECRETS
# Explicitly block standard local environment tracking files to prevent public keys from hitting the web.
.env
.env.local
.env.*.local

# 2. OMIT PYTHON BACKEND METADATA & VIRTUAL RUNTIMES
# Block local compilation engines, cache bytes, and package setup virtual environments within 'gitvibe-backend/'.
gitvibe-backend/.venv/
gitvibe-backend/venv/
gitvibe-backend/ENV/
gitvibe-backend/__pycache__/
gitvibe-backend/*.pyc
gitvibe-backend/*.pyo
gitvibe-backend/*.pyd
gitvibe-backend/.pytest_cache/
gitvibe-backend/.db
gitvibe-backend/*.db
gitvibe-backend/gitvibe.db

# 3. DROPMIN FRONTEND DEPENDENCIES & BUILD TARGETS
# Exclude compiled static bundles and local node module dependencies inside 'gitvibe-frontend/'.
gitvibe-frontend/node_modules/
gitvibe-frontend/dist/
gitvibe-frontend/build/
gitvibe-frontend/.vite/
gitvibe-frontend/*.log
gitvibe-frontend/npm-debug.log*
gitvibe-frontend/yarn-debug.log*
gitvibe-frontend/yarn-error.log*

# 4. REMOVE SYSTEM META & DOCUMENTATION DISK BLOCKS
# Instruct the index tracker to ignore hidden desktop indexing metadata along with local text guide parameters.
.DS_Store
Thumbs.db
deploy.txt
report.txt

# Additional common ignores
*.log
